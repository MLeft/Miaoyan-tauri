{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiaoYan",
  "version": "1.0.0",
  "identifier": "com.miaoyan.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MiaoYan",
        "width": 1280,
        "height": 760,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["miaoyan"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/anthropics/miaoyan/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
